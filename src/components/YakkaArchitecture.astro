---
/** Port of svg-ui CPU Architecture — https://21st.dev/community/components/svg-ui/cpu-architecture/default */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['yakka-arch', className]}
  width="100%"
  height="100%"
  viewBox="0 0 200 100"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <g
    stroke="#1c1c1c"
    fill="none"
    stroke-width="0.3"
    stroke-dasharray="100 100"
    pathLength="100"
    marker-start="url(#yakka-arch-marker)"
  >
    <path stroke-dasharray="100 100" pathLength="100" d="M 10 20 h 79.5 q 5 0 5 5 v 30"></path>
    <path stroke-dasharray="100 100" pathLength="100" d="M 180 10 h -69.7 q -5 0 -5 5 v 30"></path>
    <path d="M 130 20 v 21.8 q 0 5 -5 5 h -10"></path>
    <path d="M 170 80 v -21.8 q 0 -5 -5 -5 h -50"></path>
    <path
      stroke-dasharray="100 100"
      pathLength="100"
      d="M 135 65 h 15 q 5 0 5 5 v 10 q 0 5 -5 5 h -39.8 q -5 0 -5 -5 v -20"></path>
    <path d="M 94.8 95 v -36"></path>
    <path d="M 88 88 v -15 q 0 -5 -5 -5 h -10 q -5 0 -5 -5 v -5 q 0 -5 5 -5 h 14"></path>
    <path d="M 30 30 h 25 q 5 0 5 5 v 6.5 q 0 5 5 5 h 20"></path>
    <animate
      attributeName="stroke-dashoffset"
      from="100"
      to="0"
      dur="1s"
      fill="freeze"
      calcMode="spline"
      keySplines="0.25,0.1,0.5,1"
      keyTimes="0; 1"></animate>
  </g>

  <g mask="url(#yakka-arch-mask-1)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--1" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-2)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--2" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-3)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--3" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-4)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--4" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-5)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--5" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-6)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--6" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-7)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--7" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>
  <g mask="url(#yakka-arch-mask-8)">
    <circle class="yakka-arch__pulse yakka-arch__pulse--8" cx="0" cy="0" r="8" fill="url(#yakka-arch-pulse-grad)"
    ></circle>
  </g>

  <g>
    <g fill="url(#yakka-arch-connection-gradient)">
      <rect x="93" y="37" width="2.5" height="5" rx="0.7"></rect>
      <rect x="104" y="37" width="2.5" height="5" rx="0.7"></rect>
      <rect x="116.3" y="44" width="2.5" height="5" rx="0.7" transform="rotate(90 116.25 45.5)"></rect>
      <rect x="122.8" y="44" width="2.5" height="5" rx="0.7" transform="rotate(90 116.25 45.5)"></rect>
      <rect x="104" y="16" width="2.5" height="5" rx="0.7" transform="rotate(180 105.25 39.5)"></rect>
      <rect x="114.5" y="16" width="2.5" height="5" rx="0.7" transform="rotate(180 105.25 39.5)"></rect>
      <rect x="80" y="-13.6" width="2.5" height="5" rx="0.7" transform="rotate(270 115.25 19.5)"></rect>
      <rect x="87" y="-13.6" width="2.5" height="5" rx="0.7" transform="rotate(270 115.25 19.5)"></rect>
    </g>
    <rect x="78" y="40" width="44" height="20" rx="2" fill="#181818" filter="url(#yakka-arch-light-shadow)"></rect>
    <text
      x="100"
      y="52.5"
      font-size="5.5"
      fill="url(#yakka-arch-text-gradient)"
      font-weight="600"
      letter-spacing="0.05em"
      text-anchor="middle">YAKKA</text>
  </g>

  <defs>
    <mask id="yakka-arch-mask-1">
      <path d="M 10 20 h 79.5 q 5 0 5 5 v 24" stroke-width="0.5" stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-2">
      <path d="M 180 10 h -69.7 q -5 0 -5 5 v 24" stroke-width="0.5" stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-3">
      <path d="M 130 20 v 21.8 q 0 5 -5 5 h -10" stroke-width="0.5" stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-4">
      <path d="M 170 80 v -21.8 q 0 -5 -5 -5 h -50" stroke-width="0.5" stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-5">
      <path
        d="M 135 65 h 15 q 5 0 5 5 v 10 q 0 5 -5 5 h -39.8 q -5 0 -5 -5 v -20"
        stroke-width="0.5"
        stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-6">
      <path d="M 94.8 95 v -36" stroke-width="0.5" stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-7">
      <path
        d="M 88 88 v -15 q 0 -5 -5 -5 h -10 q -5 0 -5 -5 v -5 q 0 -5 5 -5 h 14"
        stroke-width="0.5"
        stroke="white"></path>
    </mask>
    <mask id="yakka-arch-mask-8">
      <path d="M 30 30 h 25 q 5 0 5 5 v 6.5 q 0 5 5 5 h 20" stroke-width="0.5" stroke="white"></path>
    </mask>

    <radialGradient id="yakka-arch-pulse-grad" fx="1">
      <stop offset="0%" stop-color="#dcfce7"></stop>
      <stop offset="45%" stop-color="#4ade80"></stop>
      <stop offset="100%" stop-color="transparent"></stop>
    </radialGradient>

    <filter id="yakka-arch-light-shadow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="1.5" dy="1.5" stdDeviation="1" flood-color="black" flood-opacity="0.1"></feDropShadow>
    </filter>

    <marker id="yakka-arch-marker" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="18" markerHeight="18">
      <circle cx="5" cy="5" r="2" fill="black" stroke="#232323" stroke-width="0.5">
        <animate attributeName="r" values="0; 3; 2" dur="0.5s"></animate>
      </circle>
    </marker>

    <linearGradient id="yakka-arch-connection-gradient" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#4F4F4F"></stop>
      <stop offset="60%" stop-color="#121214"></stop>
    </linearGradient>

    <linearGradient id="yakka-arch-text-gradient" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#666666">
        <animate
          attributeName="offset"
          values="-2; -1; 0"
          dur="5s"
          repeatCount="indefinite"
          calcMode="spline"
          keyTimes="0; 0.5; 1"
          keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"></animate>
      </stop>
      <stop offset="25%" stop-color="white">
        <animate
          attributeName="offset"
          values="-1; 0; 1"
          dur="5s"
          repeatCount="indefinite"
          calcMode="spline"
          keyTimes="0; 0.5; 1"
          keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"></animate>
      </stop>
      <stop offset="50%" stop-color="#666666">
        <animate
          attributeName="offset"
          values="0; 1; 2;"
          dur="5s"
          repeatCount="indefinite"
          calcMode="spline"
          keyTimes="0; 0.5; 1"
          keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"></animate>
      </stop>
    </linearGradient>
  </defs>
</svg>
